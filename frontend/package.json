{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "sync:portfolio": "node --import tsx/esm scripts/sync-portfolio-exports.mjs",
    "dev": "node --import tsx/esm scripts/sync-portfolio-exports.mjs && vite",
    "build": "node --import tsx/esm scripts/sync-portfolio-exports.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node scripts/run-vitest.mjs run --config vitest.unit.config.mts && node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:unit": "node scripts/run-vitest.mjs run --config vitest.unit.config.mts",
    "test:integration": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:coverage": "node scripts/run-vitest.mjs run --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "2.104.0",
    "@vercel/analytics": "2.0.1",
    "framer-motion": "12.38.0",
    "luxon": "3.7.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "react-simple-typewriter": "5.0.1",
    "three": "^0.184.0"
  },
  "resolutions": {
    "caniuse-lite": "^1.0.30001756"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/luxon": "3.7.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-visitor-keys": "5.0.1",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "msw": "2.13.4",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "semver": "7.7.4",
    "tailwindcss": "3.4.19",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9",
    "vitest": "4.1.5"
  }
}
