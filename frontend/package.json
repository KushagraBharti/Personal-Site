{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.17.0",
  "type": "module",
  "scripts": {
    "sync:portfolio": "node --import tsx/esm scripts/sync-portfolio-exports.mjs",
    "dev": "node --import tsx/esm scripts/sync-portfolio-exports.mjs && vite",
    "build": "node --import tsx/esm scripts/sync-portfolio-exports.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node scripts/run-vitest.mjs run --config vitest.unit.config.mts && node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:unit": "node scripts/run-vitest.mjs run --config vitest.unit.config.mts",
    "test:integration": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:smoke": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:e2e": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:coverage": "node scripts/run-vitest.mjs run --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "2.108.2",
    "@vercel/analytics": "2.0.1",
    "framer-motion": "12.40.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "react-simple-typewriter": "5.0.1",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
