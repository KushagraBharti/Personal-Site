{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/sync-portfolio-exports.ts && vite",
    "dev:test": "bun run scripts/sync-portfolio-exports.ts && vite --host 127.0.0.1 --port 5173",
    "build": "bun run scripts/sync-portfolio-exports.ts && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "node scripts/run-vitest.mjs run --config vitest.unit.config.mts",
    "test:integration": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test:coverage": "node scripts/run-vitest.mjs run --coverage",
    "test:smoke": "node ./node_modules/@playwright/test/cli.js test --project=smoke",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test --project=e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.7.7",
    "framer-motion": "^12.6.2",
    "luxon": "^3.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.4.6",
    "react-icons": "^5.5.0",
    "react-parallax-tilt": "^1.7.287",
    "react-router-dom": "^6.27.0",
    "react-simple-typewriter": "^5.0.1"
  },
  "resolutions": {
    "caniuse-lite": "^1.0.30001756"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "globals": "^15.11.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  }
}
