{
  "name": "backend",
  "version": "1.0.0",
  "packageManager": "npm@11.17.0",
  "main": "src/server.ts",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "axios": "1.18.0",
    "cors": "2.8.6",
    "express": "5.2.1",
    "luxon": "3.7.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/luxon": "3.7.2",
    "@types/node": "26.0.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "supertest": "7.2.2",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.mts && vitest run --config vitest.integration.config.mts",
    "test:unit": "vitest run --config vitest.unit.config.mts",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:coverage": "vitest run --coverage",
    "test:live": "vitest run --config vitest.live.config.mts"
  }
}
