{
  "name": "backend",
  "version": "1.0.0",
  "packageManager": "bun@1.3.13",
  "main": "src/server.ts",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "2.104.0",
    "axios": "1.17.0",
    "cors": "2.8.6",
    "es-module-lexer": "^2.0.0",
    "express": "5.2.1",
    "follow-redirects": "^1.16.0",
    "luxon": "3.7.2",
    "mime": "4.1.0",
    "mime-types": "^3.0.2",
    "proxy-from-env": "^2.1.0",
    "whatwg-url": "^16.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/connect": "3.4.38",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/luxon": "3.7.1",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.5",
    "nodemon": "3.1.14",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.mts && vitest run --config vitest.integration.config.mts",
    "test:unit": "vitest run --config vitest.unit.config.mts",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:coverage": "vitest run --coverage",
    "test:live": "vitest run --config vitest.live.config.mts"
  }
}
