{
  "version": 2,
  "builds": [
    { "src": "src/server.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/server.ts" }
  ],
  "crons": [
    { "path": "/api/private/cron/calendar-sync", "schedule": "10 2 * * *" },
    { "path": "/api/private/cron/calendar-watch-renew", "schedule": "40 2 * * *" }
  ]
}
